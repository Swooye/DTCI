.feedback-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.page-header {
  background-color: #fff;
  padding: 32rpx;
  text-align: center;
  border-bottom: 1px solid #e0e0e0;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.feedback-type-section,
.feedback-content-section,
.upload-section,
.contact-section {
  background-color: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.type-item {
  background-color: #f5f5f5;
  color: #666;
  padding: 24rpx;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  border: 2rpx solid transparent;
}

.type-item.active {
  background-color: #e6f7ff;
  color: #1890ff;
  border-color: #1890ff;
}

.feedback-textarea {
  width: 100%;
  height: 240rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.upload-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.upload-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
}

.upload-item image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d9d9d9;
}

.upload-btn image {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
}

.upload-btn text {
  font-size: 24rpx;
  color: #999;
}

.contact-input {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.submit-section {
  padding: 32rpx;
}

.submit-btn {
  background-color: #1890ff;
  color: #fff;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 32rpx;
  text-align: center;
}

.submit-btn[disabled] {
  background-color: #d9d9d9;
  color: #fff;
}

.feedback-history {
  background-color: #fff;
  padding: 32rpx;
}

.history-header {
  margin-bottom: 24rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
}

.history-content {
  flex: 1;
}

.history-type {
  display: inline-block;
  background-color: #e6f7ff;
  color: #1890ff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.history-text {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

.history-status {
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.history-status.pending {
  background-color: #fff7e6;
  color: #faad14;
}

.history-status.resolved {
  background-color: #f6ffed;
  color: #52c41a;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999;
}
