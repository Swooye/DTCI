.about-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

.logo-section {
  background-color: #1890ff;
  padding: 80rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.app-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background-color: #fff;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.intro-section,
.contact-section,
.wechat-section {
  background-color: #fff;
  padding: 40rpx 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.intro-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

.contact-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.contact-item {
  display: flex;
  align-items: center;
}

.contact-item image {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.contact-item text {
  font-size: 28rpx;
  color: #333;
}

.wechat-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.qr-code {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
  background-color: #f5f5f5;
}

.wechat-tip {
  font-size: 26rpx;
  color: #999;
}

.footer-links {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  gap: 24rpx;
}

.link-item {
  font-size: 26rpx;
  color: #1890ff;
}

.divider {
  color: #d9d9d9;
}
