@import "../../styles/rich-text.wxss";

.about-container {
  min-height: 100vh;
  background-color: #f8f9fa;
  display: flex;
  flex-direction: column;
  padding-bottom: 60rpx;
}

.content-section {
  background-color: #ffffff;
  padding: 30rpx 48rpx;
  flex: 1;
}

.rich-content--banner {
  width: 100%;
}

.footer-links {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}

.link-item {
  font-size: 24rpx;
  color: #4A90E2;
}

.divider {
  font-size: 24rpx;
  color: #dddddd;
  margin: 0 30rpx;
}
