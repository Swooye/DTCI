.container {
  min-height: 100vh;
  background-color: #f8f9fa;
}

/* 导航栏修复 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background-color: #fff;
}

.nav-content {
  display: flex;
  align-items: center;
  position: relative;
  width: 100%;
}

.nav-back {
  position: absolute;
  left: 30rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  z-index: 10;
}

.back-icon {
  font-size: 56rpx;
  color: #333;
  margin-top: -4rpx;
}

.nav-title {
  width: 100%;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.content-scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* 概况卡片 */
.overview-card {
  margin: 20rpx 30rpx 30rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}

.chart-section {
  width: 220rpx;
  display: flex;
  justify-content: center;
}

.ring-chart {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  background: #eee; /* Fallback */
}

.ring-chart::after {
  content: '';
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  background-color: #fff;
  border-radius: 50%;
}

.chart-inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.chart-inner .percent {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.chart-inner .label {
  font-size: 20rpx;
  color: #999;
}

.legend-section {
  flex: 1;
  padding-left: 40rpx;
}

.legend-title {
  font-size: 22rpx;
  color: #B2B2B2;
  margin-bottom: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}
.dot.orange { background-color: #FF9560; }
.dot.blue { background-color: #4D96FF; }
.dot.purple { background-color: #C386FF; }

.legend-item .name {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

.legend-item .val {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* Tabs */
.tabs-container {
  display: flex;
  padding: 0 30rpx 30rpx;
  gap: 20rpx;
}

.tab {
  flex: 1;
  height: 80rpx;
  background-color: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #999;
  transition: all 0.2s;
  border: 1rpx solid #fff;
}

.tab.active {
  background-color: #FFF2EF;
  color: #FF6243;
  border-color: #FF6243;
  font-weight: bold;
}

/* 列表 */
.customer-list {
  background-color: #fff;
  margin: 0 30rpx;
  border-radius: 24rpx;
  padding: 20rpx 30rpx;
  min-height: 500rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-img {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
}

.empty-main {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}

.customer-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.guest-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.guest-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.guest-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.guest-time {
  font-size: 22rpx;
  color: #B2B2B2;
}
