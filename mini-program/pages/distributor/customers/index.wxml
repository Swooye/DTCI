<view class="container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="height: {{navHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px; margin-top: {{statusBarHeight}}px;">
      <view class="nav-back" bindtap="onBackTap">
        <text class="back-icon">‹</text>
      </view>
      <view class="nav-title">我的客户</view>
    </view>
  </view>

  <scroll-view scroll-y class="content-scroll" style="padding-top: {{navHeight + 10}}px;">
    <!-- 客户概况卡片 -->
    <view class="overview-card">
      <view class="chart-section">
        <view class="ring-chart" style="background: conic-gradient(#FF9560 0% {{stats.regPercent || 0}}%, #4D96FF {{stats.regPercent || 0}}% {{stats.testPercent || 0}}%, #C386FF {{stats.testPercent || 0}}% 100%);">
          <view class="chart-inner">
            <text class="percent">{{stats.percent || '0%'}}</text>
            <text class="label">转化率</text>
          </view>
        </view>
      </view>
      <view class="legend-section">
        <view class="legend-title">客户概况 (人)</view>
        <view class="legend-item">
          <view class="dot orange"></view>
          <text class="name">注册人数</text>
          <text class="val">{{stats.regCount || 0}}</text>
        </view>
        <view class="legend-item">
          <view class="dot blue"></view>
          <text class="name">测评用户</text>
          <text class="val">{{stats.testCount || 0}}</text>
        </view>
        <view class="legend-item">
          <view class="dot purple"></view>
          <text class="name">付费用户</text>
          <text class="val">{{stats.payCount || 0}}</text>
        </view>
      </view>
    </view>

    <!-- Tabs 切换 -->
    <view class="tabs-container">
      <view class="tab {{activeTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">注册用户</view>
      <view class="tab {{activeTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">测评用户</view>
      <view class="tab {{activeTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">付费用户</view>
    </view>

    <!-- 客户列表 -->
    <view class="customer-list">
      <view wx:if="{{customers.length === 0}}" class="empty-state">
        <image class="empty-img" src="/assets/images/logo.png" mode="aspectFit" style="filter: grayscale(1); opacity: 0.3;"></image>
        <text class="empty-main">您还没有客户哦</text>
        <text class="empty-sub">快去邀请吧~</text>
      </view>
      
      <view class="customer-item" wx:for="{{customers}}" wx:key="id">
        <image class="guest-avatar" src="{{item.avatar || '/assets/images/logo.png'}}"></image>
        <view class="guest-info">
          <text class="guest-name">{{item.nickname}}</text>
          <text class="guest-time">{{item.joinDate}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
