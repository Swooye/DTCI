<view class="container">
  <view class="form-card">
    <view class="form-item">
      <view class="form-label">姓名<text class="required">*</text></view>
      <input class="form-input" placeholder="请输入姓名" placeholder-class="placeholder" value="{{formData.realName}}" bindinput="onInput" data-field="realName" />
    </view>
    
    <view class="form-item">
      <view class="form-label">手机号<text class="required">*</text></view>
      <input class="form-input" type="number" placeholder="请输入手机号" placeholder-class="placeholder" value="{{formData.phone}}" bindinput="onInput" data-field="phone" />
    </view>
    
    <view class="form-item">
      <view class="form-label">生日</view>
      <picker mode="date" value="{{formData.birthday}}" bindchange="onDateChange">
        <view class="picker-value {{formData.birthday ? '' : 'placeholder'}}">
          {{formData.birthday || '请选择生日'}}
          <text class="icon-arrow-down">∨</text>
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <view class="form-label">联系地址</view>
      <input class="form-input" placeholder="请输入联系地址" placeholder-class="placeholder" value="{{formData.address}}" bindinput="onInput" data-field="address" />
    </view>
    
    <view class="form-item border-none">
      <view class="form-label">佣金结算<text class="required">*</text></view>
      <input class="form-input" placeholder="请输入支付宝收款账号" placeholder-class="placeholder" value="{{formData.alipayAccount}}" bindinput="onInput" data-field="alipayAccount" />
    </view>
  </view>

  <view class="tips">带<text class="required">*</text>选项为必填项</view>

  <button class="submit-btn" bindtap="onSubmit">提交申请</button>
</view>
