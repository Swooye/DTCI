.container {
  min-height: 100vh;
  background-color: #fff;
  padding-bottom: 220rpx;
}

.hero-section {
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  background-color: #f0f0f5;
}

.main-content {
  padding: 40rpx;
}

.detail-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 48rpx;
}

.rich-text-content {
  font-size: 32rpx;
  color: #555;
  line-height: 1.85;
}

.rich-text-content text {
  display: block;
  margin-bottom: 30rpx;
}

/* 底部功能栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 180rpx;
  background-color: #fff;
  padding: 0 40rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, 0.04);
  z-index: 1000;
}

.btn-share {
  width: 180rpx;
  height: 100rpx;
  background-color: #F1F4F9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a1a1a;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary-wrap {
  flex: 1;
  margin-left: 20rpx;
}

.btn-primary {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FF9B6D 0%, #FF672D 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 25rpx rgba(255, 103, 45, 0.35);
}
