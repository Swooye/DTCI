.profile-container {
  min-height: 100vh;
  background-color: #f8f9fc;
  padding-bottom: 60rpx;
}

/* 页面标题 */
.page-header {
  background-color: #fff;
  padding: 40rpx 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 表单 */
.profile-form {
  margin-top: 24rpx;
  background-color: #fff;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  width: 140rpx;
  flex-shrink: 0;
}

/* 头像上传 */
.avatar-item {
  justify-content: space-between;
}

.avatar-upload-wrapper {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.avatar-upload-btn {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-end !important; /* 使内容靠右对齐 */
  background: transparent !important;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  width: auto !important;
  min-width: 0 !important;
  line-height: normal;
}

.avatar-upload-btn::after {
  border: none;
}

.avatar-preview {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  border: 2rpx solid #eee;
}

.upload-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 输入框 */
.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  text-align: right;
}

.form-input::placeholder {
  color: #bbb;
}

/* 选择器 */
.form-picker {
  flex: 1;
}

.picker-value {
  font-size: 30rpx;
  color: #333;
  text-align: right;
}

.picker-value.placeholder {
  color: #bbb;
}

/* 手机号按钮 */
.phone-btn {
  flex: 1;
  font-size: 30rpx;
  color: #FF6B35;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  text-align: right;
}

.phone-btn::after {
  border: none;
}

.phone-btn.bound {
  color: #999;
}

/* 保存按钮 */
.btn-wrapper {
  padding: 40rpx 30rpx;
  margin-top: 40rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F5E 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn::after {
  border: none;
}
