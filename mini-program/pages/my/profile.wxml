<view class="profile-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">个人信息</text>
  </view>

  <!-- 个人信息表单 -->
  <view class="profile-form">
    <!-- 头像 -->
    <view class="form-item avatar-item">
      <text class="form-label">头像</text>
      <view class="avatar-upload-wrapper">
        <button class="avatar-upload-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{avatarUrl}}" mode="aspectFill"></image>
          <text class="upload-tip">点击更换</text>
        </button>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input 
        class="form-input" 
        type="nickname" 
        placeholder="请输入昵称" 
        value="{{nickName}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <text class="form-label">性别</text>
      <picker class="form-picker" mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="picker-value {{genderIndex === -1 ? 'placeholder' : ''}}">
          {{genderIndex === -1 ? '请选择' : genderOptions[genderIndex]}}
        </view>
      </picker>
    </view>

    <!-- 城市 -->
    <view class="form-item">
      <text class="form-label">城市</text>
      <input 
        class="form-input" 
        type="text" 
        placeholder="请输入所在城市" 
        value="{{city}}"
        bindinput="onCityInput"
      />
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <text class="form-label">手机号</text>
      <button 
        class="phone-btn {{hasPhone ? 'bound' : ''}}" 
        open-type="getPhoneNumber" 
        bindgetphonenumber="onGetPhoneNumber"
      >
        {{hasPhone ? phoneDisplay : '获取手机号'}}
      </button>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="btn-wrapper">
    <button class="save-btn" bindtap="onSave">保存</button>
  </view>
</view>
