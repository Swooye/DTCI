<view class="container">
  <!-- 头部：头像 + 点击登录 + 设置图标 -->
  <view class="profile-header">
    <view class="header-main" bindtap="onLoginTap">
      <view class="avatar-wrapper">
        <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFit"></image>
      </view>
      <text class="nickname">{{userInfo.nickName}}</text>
    </view>
    <view class="header-right-actions">
      <view class="notification-entry" bindtap="onNotificationsTap">
        <view class="icon-bell"></view>
        <view class="unread-badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
      </view>
      <view class="settings-entry" bindtap="onSettingsTap">
        <view class="icon-gear"></view>
      </view>
    </view>
  </view>

  <view class="content-body">
    <!-- 分销卡片 (深色) -->
    <view class="distributor-card">
      <view class="card-left">
        <text class="icon-user-plus">👤+</text>
        <text class="card-text">成为了庸分销商</text>
      </view>
      <view class="card-right">
        <text class="promo-text">可享额外提成</text>
        <text class="arrow-gold">›</text>
      </view>
    </view>

    <!-- 统计区块 -->
    <view class="stats-card">
      <view class="stat-item" bindtap="onReportsTap">
        <view class="stat-main">
          <text class="count-value">{{stats.reports}}</text>
        </view>
        <view class="stat-label">我的报告</view>
      </view>
      <view class="stat-item" bindtap="onLikedCasesTap">
        <view class="stat-main">
          <text class="count-value">{{stats.likes}}</text>
        </view>
        <view class="stat-label">点赞案例</view>
      </view>
      <view class="stat-item" bindtap="onStarredCasesTap">
        <view class="stat-main">
          <text class="count-value">{{stats.stars}}</text>
        </view>
        <view class="stat-label">收藏案例</view>
      </view>
    </view>

    <!-- 菜单列表 -->
    <view class="menu-group">
      <view class="menu-item" wx:for="{{menus}}" wx:key="id" bindtap="onMenuClick" data-id="{{item.id}}">
        <view class="menu-item-left">
          <view class="menu-icon {{item.iconClass}}"></view>
          <text class="menu-title">{{item.name}}</text>
        </view>
        <view class="menu-item-right">
          <view class="arrow-grey-icon"></view>
        </view>
      </view>
    </view>

    <!-- 营销 Banner -->
    <view class="promo-banner">
      <view class="promo-content">
        <view class="promo-title">限时推广，拿高额佣金</view>
      </view>
      <view class="get-btn">去领取</view>
    </view>
  </view>

  <!-- 底部 TabBar -->
  <view class="tab-bar">
    <view class="tab-item-nav" bindtap="onHomeTap">
      <view class="tab-icon home-icon"></view>
      <text>首页</text>
    </view>
    <view class="tab-item-nav" bindtap="onCaseTap">
      <view class="tab-icon case-icon"></view>
      <text>案例</text>
    </view>
    <view class="tab-item-nav tab-center" bindtap="onTestTap">
      <view class="test-btn-wrapper">
        <view class="test-btn-inner">
          <text>测</text>
        </view>
      </view>
    </view>
    <view class="tab-item-nav" bindtap="onServiceTap">
      <view class="tab-icon service-icon"></view>
      <text>服务</text>
    </view>
    <view class="tab-item-nav active">
      <view class="tab-icon my-icon">
        <view class="tab-dot" wx:if="{{unreadCount > 0}}"></view>
      </view>
      <text>我的</text>
    </view>
  </view>
</view>
