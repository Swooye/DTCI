.detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.detail-swiper {
  height: 500rpx;
  background-color: #fff;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.service-baseinfo {
  background-color: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.price {
  font-size: 48rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.original-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.service-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.service-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tag {
  background-color: #e6f7ff;
  color: #1890ff;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.service-stats {
  display: flex;
  gap: 32rpx;
  color: #999;
  font-size: 24rpx;
}

.service-detail {
  background-color: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.detail-header {
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.detail-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.notice-section {
  background-color: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.notice-header {
  margin-bottom: 24rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-item {
  display: flex;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.notice-index {
  flex-shrink: 0;
  margin-right: 8rpx;
}

.notice-text {
  flex: 1;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1px solid #e0e0e0;
}

.action-icons {
  display: flex;
  gap: 32rpx;
}

.action-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon-item image {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.action-icon-item text {
  font-size: 20rpx;
  color: #666;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.btn-consult {
  background-color: #fff;
  color: #1890ff;
  border: 1px solid #1890ff;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.btn-book {
  background-color: #1890ff;
  color: #fff;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1px solid #e0e0e0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 40rpx;
  height: 40rpx;
}

.modal-body {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.success-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.appointment-info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.modal-footer {
  padding: 0 32rpx 32rpx;
}

.btn-primary {
  background-color: #1890ff;
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
  text-align: center;
}
