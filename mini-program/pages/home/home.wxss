.tab-item text {
  font-size: 22rpx;
  color: #999;
}

.tab-item.active text {
  color: #FF6B35;
  font-weight: 500;
}

/* 底部中央悬浮“测”按钮 */
.tab-center {
  position: relative;
}

.test-btn-wrapper {
  position: absolute;
  bottom: 0; /* 贴紧底部排列 */
  left: 50%;
  transform: translateX(-50%);
  width: 140rpx;
  height: 140rpx;
  background-color: #fff; /* 形成白色圆角背景，对 tab bar 产生“裁切”效果 */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 -4rpx 10rpx rgba(0, 0, 0, 0.03); /* 为了边缘轮廓过渡更自然 */
  z-index: 101;
}

.test-btn-inner {
  width: 114rpx;
  height: 114rpx;
  background: linear-gradient(135deg, #FF8F5E 0%, #FF6B35 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 53, 0.3);
}

.test-btn-inner text {
  font-size: 42rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}
