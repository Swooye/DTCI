<view class="home-container">
  <!-- 顶部标题 -->
  <view class="header-section">
    <text class="header-title">了庸文化</text>
  </view>

  <!-- 公司简介 (MVV) -->
  <view class="mvv-card">
    <view class="mvv-item" wx:if="{{vision}}">
      <view class="mvv-label-wrap">
        <view class="mvv-bar"></view>
        <text class="mvv-label">愿 景</text>
      </view>
      <text class="mvv-content">{{vision}}</text>
    </view>
    <view class="mvv-line" wx:if="{{vision && (mission || values)}}"></view>

    <view class="mvv-item" wx:if="{{mission}}">
      <view class="mvv-label-wrap">
        <view class="mvv-bar"></view>
        <text class="mvv-label">使 命</text>
      </view>
      <text class="mvv-content">{{mission}}</text>
    </view>
    <view class="mvv-line" wx:if="{{mission && values}}"></view>
    
    <view class="mvv-item" wx:if="{{values}}">
      <view class="mvv-label-wrap">
        <view class="mvv-bar"></view>
        <text class="mvv-label">理 念</text>
      </view>
      <text class="mvv-content">{{values}}</text>
    </view>
    
    <view class="empty-state" wx:if="{{!mission && !vision && !values}}">暂无公司简介</view>
  </view>

  <!-- 创始人故事 -->
  <view class="section">
    <view class="section-title">
      <text class="dot">·</text>
      <text>创始人故事</text>
      <text class="dot">·</text>
    </view>
    <view class="founder-video-container">
      <video 
        wx:if="{{founderVideo}}"
        src="{{founderVideo}}" 
        class="founder-real-video"
        object-fit="cover"
        controls
      ></video>
      <view class="founder-video" bindtap="onPlayVideo" wx:else>
        <!-- 暂留空白灰底 -->
        <image class="founder-image" src="/assets/images/founder.jpg" mode="aspectFill"></image>
        <view class="play-btn">
          <view class="play-icon"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 服务对比 -->
  <view class="section">
    <view class="section-title">
      <text class="dot">·</text>
      <text>服务对比</text>
      <text class="dot">·</text>
    </view>
    <view class="compare-container">
      <image 
        wx:if="{{serviceImage}}"
        src="{{serviceImage}}" 
        mode="widthFix" 
        class="service-compare-image"
      ></image>
      <view class="empty-state" wx:else>暂无服务对比</view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>

  <!-- 底部导航 -->
  <view class="tab-bar">
    <view class="tab-item active">
      <view class="tab-icon home-icon"></view>
      <text>首页</text>
    </view>
    <view class="tab-item" bindtap="onCaseTap">
      <view class="tab-icon case-icon"></view>
      <text>案例</text>
    </view>
    <view class="tab-item tab-center" bindtap="onTestTap">
      <!-- 修改为包含外侧白边的独立容器结构 -->
      <view class="test-btn-wrapper">
        <view class="test-btn-inner">
          <text>测</text>
        </view>
      </view>
    </view>
    <view class="tab-item" bindtap="onServiceTap">
      <view class="tab-icon service-icon"></view>
      <text>服务</text>
    </view>
    <view class="tab-item" bindtap="onMyTap">
      <view class="tab-icon my-icon">
        <view class="tab-dot" wx:if="{{unreadCount > 0}}"></view>
      </view>
      <text>我的</text>
    </view>
  </view>
</view>
