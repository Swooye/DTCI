<view class="container">
  <!-- 顶部标题与版标 -->
  <view class="header">
    <view class="title">DTCI 人格测评</view>
    <view class="gender-badge">{{name || '测评'}}</view>
  </view>

  <scroll-view scroll-y class="main-scroll" show-scrollbar="{{false}}" wx:if="{{!loading}}">
    <!-- 答题卡片 -->
    <view class="question-card">
      <view class="progress-wrap">
        <text class="current-num">{{currentIndex + 1}} <text class="total-num">/{{totalCount}}</text></text>
        <view class="progress-bar">
          <view class="progress-inner" style="width: {{(currentIndex + 1) / totalCount * 100}}%"></view>
        </view>
      </view>

      <view class="question-title">{{currentQuestion.title}}</view>

      <view class="options-list">
        <view 
          class="option-item {{selectedId === item.label ? 'active' : ''}}" 
          wx:for="{{options}}" 
          wx:key="label"
          bindtap="onSelectOption"
          data-id="{{item.label}}"
        >
          <text class="option-label">{{item.label}}：</text>
          <text class="option-text">{{item.text}}</text>
        </view>
      </view>

      <!-- 题目导航 -->
      <view class="nav-links">
        <view class="nav-btn prev" bindtap="onPrev">
          <text class="arrow">←</text> 上一题
        </view>
        <view class="nav-btn next {{selectedId ? 'highlight' : ''}}" bindtap="onNext">
          下一题 <text class="arrow">→</text>
        </view>
      </view>
    </view>

    <!-- 底部权益展示（持久化） -->
    <view class="benefits-section">
      <view class="section-divider">测试完成后，您会获得</view>
      <view class="benefits-grid">
        <view class="benefit-item" wx:for="{{benefits}}" wx:key="*this">
          <text class="dot">•</text>
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>
</view>
