.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E6F3FF 0%, #FFFFFF 400rpx);
}

.header {
  padding: 60rpx 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
  color: #1A2751;
  margin-bottom: 20rpx;
}

.gender-badge {
  background-color: #0095FF;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 32rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 149, 255, 0.3);
}

.main-scroll {
  height: calc(100vh - 200rpx);
}

.question-card {
  background-color: #fff;
  margin: 40rpx 32rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.05);
}

/* 进度条 */
.progress-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
}

.current-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF672D;
  margin-right: 20rpx;
}

.total-num {
  color: #aaa;
  font-size: 24rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background-color: #f0f0f5;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #FF9B6D, #FF672D);
  border-radius: 10rpx;
  transition: width 0.3s;
}

/* 题目 */
.question-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.6;
  margin-bottom: 60rpx;
}

/* 选项 */
.option-item {
  background-color: #F8F9FB;
  border: 4rpx solid transparent;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  transition: all 0.2s;
}

.option-item.active {
  background-color: #FFF9F6;
  border-color: #FFB18E;
  box-shadow: 0 8rpx 20rpx rgba(255, 125, 73, 0.1);
}

.option-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.option-text {
  font-size: 30rpx;
  color: #333;
}

/* 导航按钮 */
.nav-links {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
  padding-top: 30rpx;
}

.nav-btn {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #FF672D;
}

.nav-btn.next.highlight {
  font-weight: bold;
}

.nav-btn .arrow {
  margin: 0 10rpx;
  font-weight: bold;
}

/* 权益展示板块复制 index */
.benefits-section { margin: 40rpx 32rpx; background-color: #fff; border-radius: 24rpx; padding: 40rpx 30rpx; }
.section-divider { display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 40rpx; }
.section-divider::before, .section-divider::after { content: ""; flex: 1; height: 2rpx; background-color: #eee; margin: 0 30rpx; }
.benefits-grid { display: flex; flex-wrap: wrap; }
.benefit-item { width: 33.33%; display: flex; align-items: center; padding: 16rpx 0; font-size: 24rpx; color: #333; }
.benefit-item .dot { margin-right: 12rpx; color: #000; font-weight: bold; }

.bottom-spacer { height: 100rpx; }
