<view class="container">
  <!-- 侧边悬浮：我的报告 -->
  <view class="side-float-tab" bindtap="onMyReportTap">
    <text>我\n的\n报\n告</text>
  </view>

  <!-- 头部文案 -->
  <view class="hero-section">
    <view class="main-title">DTCI 135型人格测评</view>
    <view class="subtitle-badge">135 Personalities</view>
    <view class="intro-card-box">
      我是谁？优势与短板何在？职业天赋与潜能是什么？怎样的伴侣与我契合？DTCI助你解码未知自我，开启探索之旅！
    </view>
  </view>

  <!-- 问卷选择区 -->
  <block wx:if="{{questionnaires.length > 0}}">
    <view class="version-selection {{questionnaires.length === 1 ? 'centered' : ''}} {{questionnaires.length > 2 ? 'scrollable' : ''}}">
      <scroll-view scroll-x="{{questionnaires.length > 2}}" class="selection-box">
        <view class="selection-inner">
          <view 
            wx:for="{{questionnaires}}" 
            wx:key="id"
            class="version-card {{selectedId === item.id ? 'active' : ''}}" 
            bindtap="onSelectQuestionnaire" 
            data-id="{{item.id}}"
          >
            <view class="card-badge" wx:if="{{item.settings.duration}}">预计 · {{item.settings.duration}}分钟</view>
            <view class="card-image-box">
              <image class="card-icon" src="{{item.wechatConfig.icon ? (item.wechatConfig.icon.startsWith('http') ? item.wechatConfig.icon : BASE_URL + item.wechatConfig.icon) : '/assets/images/logo.png'}}" mode="aspectFill"></image>
            </view>
            <view class="card-title">{{item.name}}</view>
            <view class="card-desc">{{item.description || '解锁探索你的DTCI天命人格'}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </block>

  <!-- 空态提示 -->
  <view class="empty-state" wx:else>
    <image class="empty-icon" src="/assets/images/logo.png" mode="aspectFit"></image>
    <view class="empty-text">测评正在筹备中，敬请期待...</view>
  </view>

  <!-- 引导语 -->
  <view class="guide-text">
    <view class="guide-title">您知道自己的天命人格吗？</view>
    <view class="guide-link">点击 <text class="highlight">「开始测试」</text> 探索你的DTCI人格吧！</view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="action-footer">
    <view class="btn-share" bindtap="onShare">分享</view>
    <view class="btn-primary" bindtap="onStart">
      <text>开始测评</text>
      <view class="arrow-icon">▶</view>
    </view>
  </view>

  <!-- 测试获益展示 -->
  <view class="benefits-section">
    <view class="section-divider">测试完成后，您会获得</view>
    <view class="benefits-grid">
      <view class="benefit-item" wx:for="{{benefits}}" wx:key="index">
        <text class="dot">•</text>
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 付费声明 -->
  <view class="notice-section">
    <view class="section-divider">付费测评，测试结果仅供参考</view>
    <view class="notice-list">
      <view class="notice-item" wx:for="{{notes}}" wx:key="index">
        <view class="index">{{index + 1}}</view>
        <view class="text">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="bottom-spacer"></view>

  <!-- 底部导航占位 (如果 assessment 是独立页面非 TabBar) -->
  <!-- 在此项目中，"测" 是 TabBar 中心大按钮触发的，所以这里保留与 TabBar 视觉的一致性 -->
</view>
