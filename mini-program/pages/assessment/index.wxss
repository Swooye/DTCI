.container {
  min-height: 100vh;
  background-color: #F8F9FB; /* 整体页面底色改浅灰 */
  padding: 40rpx 32rpx;
  position: relative;
  box-sizing: border-box;
}

/* 顶部蓝色渐变背景层 */
.container::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 600rpx;
  background: linear-gradient(180deg, #E6F3FF 0%, rgba(230, 243, 255, 0) 100%);
  z-index: 0;
  pointer-events: none;
}

.side-float-tab, .hero-section, .version-selection, .guide-text, .action-footer, .benefits-section, .notice-section {
  position: relative;
  z-index: 1;
}

/* 侧边悬浮：我的报告 */
.side-float-tab {
  position: fixed;
  right: 0;
  top: 15vh;
  background-color: #333;
  color: #fff;
  font-size: 20rpx;
  padding: 20rpx 8rpx;
  border-radius: 16rpx 0 0 16rpx;
  line-height: 1.4;
  text-align: center;
  z-index: 1000;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

/* 头部文案 */
.hero-section {
  text-align: center;
  margin-top: 20rpx;
  margin-bottom: 60rpx;
}

.main-title {
  font-size: 60rpx; /* 略微调小一点点更协调 */
  font-weight: 800;
  color: #1A2751;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.subtitle-badge {
  display: inline-block;
  background-color: #fff;
  color: #8E96A4;
  font-size: 26rpx;
  padding: 12rpx 36rpx;
  border-radius: 12rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.intro-card-box {
  background-color: #fff;
  padding: 36rpx 44rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #1A2751;
  line-height: 1.8;
  text-align: left;
  box-shadow: 0 12rpx 40rpx rgba(26, 39, 81, 0.05);
}

/* 版本选择区 */
.version-selection {
  margin-bottom: 70rpx;
  padding-top: 40rpx; /* 增加顶部间距防止顶部边框/角标被遮挡 */
  width: 100%;
}

.version-selection.centered .selection-inner {
  justify-content: center;
}

.selection-box {
  width: 100%;
  white-space: nowrap;
  overflow: visible; /* 确保阴影和边位极其出的内容不会被截断 */
}

.selection-inner {
  display: flex;
  justify-content: space-between;
  gap: 28rpx;
  min-width: 100%;
  padding: 20rpx 10rpx 40rpx; /* 基础边距，防止上下阴影及角标被截断 */
  box-sizing: border-box;
}

.version-selection.scrollable .selection-inner {
  padding: 20rpx 40rpx 40rpx; /* 增加内边距防止阴影裁剪 */
}

.version-card {
  flex: 0 0 330rpx;
  background-color: #fff;
  border-radius: 40rpx;
  padding: 60rpx 24rpx 40rpx;
  text-align: center;
  position: relative;
  box-sizing: border-box;
  /* 使用阴影模拟边框，渲染更加细腻且不易被裁切 */
  box-shadow: 0 0 0 4rpx #F5F6F8, 0 10rpx 40rpx rgba(0,0,0,0.03); 
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: inline-block;
  vertical-align: top;
  white-space: normal;
}

.version-selection:not(.scrollable) .version-card {
  flex: 1;
  max-width: 340rpx; /* 防止两个卡片太大 */
}

.version-selection.centered .version-card {
  flex: 0 0 500rpx;
  max-width: 500rpx;
}

.version-card.active {
  background-color: #FFF9F6;
  /* 激活状态使用橙色阴影模拟边框 */
  box-shadow: 0 0 0 4rpx #FFB18E, 0 20rpx 50rpx rgba(255, 125, 73, 0.12);
  transform: translateY(-4rpx);
}

.card-badge {
  position: absolute;
  top: -4rpx; /* 严格对齐模拟边框的外沿 */
  right: -4rpx;
  background: linear-gradient(90deg, #FF9B6D, #FF672D);
  color: #fff;
  font-size: 18rpx;
  padding: 10rpx 24rpx;
  border-radius: 0 40rpx 0 24rpx;
  font-weight: bold;
  z-index: 5;
  box-shadow: -4rpx 4rpx 10rpx rgba(255, 103, 45, 0.15);
}

.card-image-box {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 30rpx;
  border-radius: 60rpx;
  overflow: hidden;
  background-color: #F8F9FB;
  border: 2rpx solid rgba(0,0,0,0.05);
}

.card-icon {
  width: 100%;
  height: 100%;
}

.card-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1A2751;
  margin-bottom: 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-desc {
  font-size: 24rpx;
  color: #8E96A4;
  margin-bottom: 20rpx;
  line-height: 1.4;
  height: 68rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 空态样式 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
  background: #fff;
  border-radius: 32rpx;
  margin-bottom: 70rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.03);
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #8E96A4;
}

/* 引导语 */
.guide-text {
  text-align: center;
  margin-bottom: 60rpx;
}

.guide-title {
  font-size: 44rpx; /* 根据截图调大 */
  font-weight: bold;
  color: #1A2751;
  margin-bottom: 16rpx;
}

.guide-link {
  font-size: 32rpx;
  color: #8E96A4;
}

.highlight {
  color: #FF672D;
  font-weight: 600;
  margin: 0 4rpx;
}

/* 底部操作按钮 - 精确对齐 30%:70% 比例 */
.action-footer {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 80rpx;
  padding: 0 10rpx;
}

.btn-share {
  width: 210rpx; /* 调整宽度 */
  height: 100rpx; /* 高度设为 100rpx */
  background-color: #fff;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A2751;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
  flex-shrink: 0;
  padding: 0; /* 强制重置 padding */
  box-sizing: border-box;
}

.btn-primary {
  flex: 1; 
  height: 100rpx; /* 高度设为 100rpx，与分享按钮严格一致 */
  background: linear-gradient(135deg, #FF9B6D 0%, #FF672D 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 12rpx 30rpx rgba(255, 103, 45, 0.3);
  padding: 0; /* 强制重置继承的 padding (from app.wxss) */
  box-sizing: border-box;
}

.btn-primary text {
  /* 移除之前的 margin-left 偏移，靠 flex 居中 */
}

.btn-primary .arrow-icon {
  margin-left: 12rpx;
  font-size: 22rpx;
}

/* 分割线与板块 */
.section-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #1A2751;
  margin-bottom: 40rpx;
}

.section-divider::before, .section-divider::after {
  content: "";
  flex: 1;
  height: 1rpx; /* 极细线 */
  background-color: #EBD9D9; /* 颜色略浅 */
  margin: 0 30rpx;
  opacity: 0.5;
}

.benefits-section {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 56rpx 24rpx; /* 减少左右内边距以回收空间 */
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.02);
}

.benefits-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between; /* 使三列分布更均衡 */
}

.benefit-item {
  width: 31%; /* 略微减小宽度，配合 space-between */
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #1A2751;
  box-sizing: border-box;
  white-space: nowrap;
}

.benefit-item .dot {
  margin-right: 8rpx; /* 缩小间距 */
  color: #1A2751;
  font-weight: bold;
  font-size: 26rpx;
  line-height: 1;
}

/* 付费须知 - 解决文案换行对齐问题 */
.notice-section {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 56rpx 32rpx;
  margin-bottom: 40rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start; /* 顶部对齐 */
  margin-bottom: 40rpx;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.notice-item .index {
  width: 44rpx;
  height: 44rpx;
  background-color: #E6F3FF;
  color: #1B78F1;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  font-weight: bold;
}

.notice-item .text {
  flex: 1; /* 确保文字占据剩余宽度并自行换行 */
  font-size: 28rpx;
  color: #616E88;
  line-height: 1.8;
  text-align: justify;
}

.bottom-spacer {
  height: 180rpx;
}
