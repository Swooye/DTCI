<view class="container">
  
  <!-- 页面主内容区 -->
  <view class="detail-body">
    <!-- 用户信息 -->
    <view class="author-info">
      <image class="avatar" src="{{caseItem.avatar}}" mode="aspectFill"></image>
      <view class="author-text">
        <text class="author-name">{{caseItem.author}}</text>
        <text class="post-date">{{caseItem.date}}</text>
      </view>
    </view>

    <!-- 标题区 -->
    <view class="detail-title">{{caseItem.title}}</view>

    <!-- 正文长文区 -->
    <rich-text nodes="{{caseItem.content}}" class="detail-content"></rich-text>
  </view>

  <!-- 吸底悬浮操作栏 -->
  <view class="bottom-action-bar">
    <view class="theme-tag" style="color: {{caseItem.tagColor}};">{{caseItem.tag}}</view>
    
    <view class="action-group">
      <!-- 喜欢 -->
      <view class="action-item {{caseItem.isLiked ? 'liked' : ''}}">
        <text class="icon">♡</text> 
        <text>{{caseItem.likes}}</text>
      </view>
      <!-- 收藏 -->
      <view class="action-item {{caseItem.isLiked ? 'liked' : ''}}">
        <text class="icon">☆</text>
        <text>{{caseItem.stars}}</text>
      </view>
      <!-- 转发 -->
      <view class="action-item">
        <text class="icon">➦</text>
        <text>{{caseItem.shares}}</text>
      </view>
    </view>
  </view>
</view>
